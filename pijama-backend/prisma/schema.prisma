generator client {
  provider = "prisma-client-js"
  output   = "../src/@types/prisma"
}

datasource db {
  provider = "postgresql"
}

enum USER_ROLE {
  ADMIN
  DEFAULT
}

enum PAJAMA_SIZE {
  PP
  P
  M
  G
  GG
}

model User {
  id        Int      @id @default(autoincrement())
  publicId  String   @unique @default(uuid()) @map("public_id")
  name      String
  username  String   @unique
  email     String   @unique
  passwordHash  String @map("password_hash")
  role     USER_ROLE @default(DEFAULT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  feedbacks Feedback[]
  sales     Sale[]

  @@map("users")
}

model Feedback {
  id          Int      @id @default(autoincrement())
  publicId    String   @unique @default(uuid()) @map("public_id")
  name        String
  description String
  rating      Float
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId Int?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("feedbacks")
}

model Pajama {
  id          Int      @id @default(autoincrement())
  publicId    String   @unique @default(uuid()) @map("public_id")
  name        String
  description String
  image       String
  price       Float
  season      String
  type        String
  gender      String
  favorite    Boolean  @default(false)
  onSale      Boolean  @default(false)
  salePercent Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sizes PajamaSize[]
  sales SalePajama[]

  @@map("pajamas")
}

model PajamaSize {
  id            Int    @id @default(autoincrement())
  publicId      String @unique @default(uuid()) @map("public_id")
  size          PAJAMA_SIZE
  stockQuantity Int

  pajamaId Int
  pajama   Pajama @relation(fields: [pajamaId], references: [id], onDelete: Cascade)

  @@map("pajama_sizes")
}

model Sale {
  id            Int      @id @default(autoincrement())
  publicId      String   @unique @default(uuid()) @map("public_id")
  buyerName     String
  cpf           String
  paymentMethod String
  installments  Int      @default(1)
  cardNumber    String?
  totalAmount   Float
  totalPajamas  Int 
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  addressId Int
  address   Address @relation(fields: [addressId], references: [id], onDelete: Cascade)

  pajamas SalePajama[]

  @@map("sales")
}

model Address {
  id           Int      @id @default(autoincrement())
  publicId     String   @unique @default(uuid()) @map("public_id")

  zipCode      String
  state        String
  city         String
  neighborhood String
  address      String 
  number       String

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sales Sale[]

  @@map("addresses")
}

model SalePajama {
  id       Int    @id @default(autoincrement())
  publicId String @unique @default(uuid()) @map("public_id")
  quantity Int
  price    Float

  saleId Int
  sale   Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  pajamaId Int
  pajama   Pajama @relation(fields: [pajamaId], references: [id], onDelete: Cascade)

  @@unique([saleId, pajamaId])
  @@map("sale_pajamas")
}
